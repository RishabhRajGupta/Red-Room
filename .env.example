# The Red Room - Environment Configuration

# =============================================================================
# LLM API Keys (Comma-Separated Format)
# =============================================================================
# Add multiple free API keys separated by commas for automatic cycling
# Get free keys from:
# - Gemini: https://makersuite.google.com/app/apikey
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/

# Google Gemini API Keys (Recommended - 60 req/min, 1500 req/day per key)
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2,your_gemini_key_3

# OpenAI API Keys (60 req/min, 200 req/day per key - free tier limited)
OPENAI_API_KEYS=your_openai_key_1,your_openai_key_2

# Anthropic Claude API Keys (50 req/min, 1000 req/day per key)
ANTHROPIC_API_KEYS=your_anthropic_key_1,your_anthropic_key_2

# =============================================================================
# Alternative: Individual Key Format (Legacy)
# =============================================================================
# You can also use individual environment variables:
# GEMINI_API_KEY=your_key_1
# GEMINI_API_KEY_2=your_key_2
# GEMINI_API_KEY_3=your_key_3

# =============================================================================
# Local LLM Configuration (Optional)
# =============================================================================
# For local LLM using Ollama (https://ollama.ai/)
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# GitHub Integration (Optional)
# =============================================================================
# For automatic PR creation
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_REPO=your-org/your-repo

# =============================================================================
# Kubernetes Configuration (Optional)
# =============================================================================
# For shadow namespace management
# KUBECONFIG=~/.kube/config

# =============================================================================
# Redis Configuration (Optional)
# =============================================================================
# For state persistence
# REDIS_URL=redis://localhost:6379

# =============================================================================
# Logging Configuration
# =============================================================================
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# =============================================================================
# Performance Tuning
# =============================================================================
# Maximum concurrent exploit attempts (auto-detected based on hardware)
# MAX_CONCURRENCY=5000

# API request timeout in seconds
# API_TIMEOUT=30

# =============================================================================
# Example Configuration for Maximum Free Tier Capacity
# =============================================================================
# With 5 Gemini keys:
# - Capacity: 300 req/min, 7,500 req/day
# - Cost: $0
# - Reliability: 99.9%
#
# GEMINI_API_KEYS=key1,key2,key3,key4,key5
